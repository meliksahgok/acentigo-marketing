# Kanonik site adresi (SEO: sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL="https://acentigo.com"

# PostgreSQL (Vercel / Neon / Docker — SQLite artık kullanılmıyor)
# Yerel (docker compose postgres): postgresql://acentigo:acentigo@localhost:5432/acentigo?schema=public
# Neon: bağlantı dizesinde genelde ?sslmode=require bulunur
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth
NEXTAUTH_SECRET="yerine-guclu-rastgele-metin-yazin"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# İlk admin (seed)
ADMIN_EMAIL="admin@acentigo.com"
ADMIN_PASSWORD="degistir123"
