# Kanonik site adresi (SEO: sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL="https://acentigo.com"

# PostgreSQL (Vercel / Neon / Docker — SQLite artık kullanılmıyor)
# Yerel Docker: aşağıdaki ikisine de aynı connection string’i verin.
# Neon: Dashboard’daki pooled → DATABASE_URL, unpooled/direct → DATABASE_URL_UNPOOLED
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# NextAuth
NEXTAUTH_SECRET="yerine-guclu-rastgele-metin-yazin"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# İlk admin (npm run db:seed veya aşağıdaki tek seferlik bootstrap)
ADMIN_EMAIL="admin@acentigo.com"
ADMIN_PASSWORD="degistir123"
# Opsiyonel: üretimde kullanıcı yokken POST /api/bootstrap-admin için (sonra kaldırın)
# ADMIN_SETUP_KEY="uzun-rastgele-anahtar"
