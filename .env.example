# Veritabanı (SQLite — geliştirme). Üretimde PostgreSQL connection string kullanın.
DATABASE_URL="file:./dev.db"

# NextAuth: openssl rand -base64 32 benzeri güçlü bir değer
NEXTAUTH_SECRET="yerine-guclu-rastgele-metin-yazin"
# Yerelde localhost; canlıda tarayıcıdaki adresle birebir aynı olmalı (www ile/without tutarlı)
NEXTAUTH_URL="http://localhost:3000"
# Vercel / ters vekil: host doğrulama sorunlarında true deneyin
AUTH_TRUST_HOST="true"

# İlk admin (seed ile oluşturulur)
ADMIN_EMAIL="admin@acentigo.com"
ADMIN_PASSWORD="degistir123"
